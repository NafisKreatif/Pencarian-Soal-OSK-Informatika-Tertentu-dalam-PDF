<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.geometry.Insets?>
<BorderPane xmlns="http://javafx.com/javafx/21.0.2" xmlns:fx="http://javafx.com/fxml/1" fx:controller="osk.app.MainController"
   stylesheets="@App.css">
   <left>
      <VBox prefWidth="300">
         <Label text="Search"/>
         <Button fx:id="searchButton" text="Cari Soal"/>
      </VBox>
      <padding>
         <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
      </padding>
   </left>
   <right>
      <VBox prefWidth="300">
         <Label text="Result"/>
      </VBox>
      <padding>
         <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
      </padding>
   </right>
   <center>
      <VBox minWidth="500">
         <HBox alignment="CENTER" spacing="10">
            <Label fx:id="pdfNameLabel" text="No file opened"/>
            <Separator orientation="VERTICAL"/>
            <Label fx:id="pageLabel" text="Total Page 0"/>
            <Separator orientation="VERTICAL"/>
            <Button fx:id="closePdfButton" text="Close PDF" onAction="#closePDF" disable="true"/>
         </HBox>
         <AnchorPane VBox.vgrow="ALWAYS">
            <ScrollPane AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0"
               fitToWidth="true">
               <VBox fx:id="pdfImageVBox" alignment="CENTER" spacing="10">
               </VBox>
            </ScrollPane>
            <VBox fx:id="openPdfButton" AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0"
               alignment="CENTER" styleClass="pdf-open" onMouseClicked="#loadPDF">
               <VBox VBox.vgrow="ALWAYS" alignment="CENTER" style="-fx-border-style: dashed; -fx-border-width: 2; -fx-border-radius: 10">
                  <Label text="Open PDF File"/>
               </VBox>
               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
               </padding>
            </VBox>
         </AnchorPane>
      </VBox>
   </center>
</BorderPane>
